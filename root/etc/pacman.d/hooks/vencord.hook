[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = discord

[Action]
Description = Re-patch vencord after discord install/upgrade
When = PostTransaction
Depends = vencord-installer-cli-bin
Exec = /usr/bin/env bash -c '/usr/bin/vencordinstallercli -repair -location /home/$(logname)/.config/discord/$(ls /home/$(logname)/.config/discord/ | grep "app-" | sort -V | tail -1)'
