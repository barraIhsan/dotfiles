{{- $chezmoiData := deepCopy . -}}
{{- $chezmoiDiff := $chezmoiData.chezmoi.config.diff }}
{{- $chezmoiData = unset $chezmoiData "chezmoi" -}}

{{- $sourceDir := joinPath .chezmoi.workingTree "root" -}}
sourceDir = "{{ $sourceDir }}"
destDir   = "/"
verbose   = true
[diff]
  exclude = ["scripts"]
[status]
  exclude = ["scripts"]
[data]
  non_root_user = "{{ .chezmoi.username }}"
{{ $chezmoiData | toToml }}
# vim: filetype=toml
